{erl_opts, [debug_info]}.
{deps, []}.

{plugins, [{rebar3_ex_doc, "0.2.30"},
           {rebar3_dialyzer_html, "0.2.0"}]}.

{ex_doc, [{extras, ["README.md", "LICENSE"]},
          {main, "README.md"},
          {source_url, "https://github.com/haruki7049/yaerltui"}]}.

{shell, [
         %% {config, "config/sys.config"},
         {apps, [yaerltui]}]}.
